{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Hades Schema Registry - per-operation resource usage: RAM (alloc delta), CPU (latency proxy), Storage I/O (proto/output bytes), GC pressure, and Go runtime. Includes Gitaly and S3 sub-phase breakdowns.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200, "title": "Go Process (system-wide)", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 }, "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "go_memstats_alloc_bytes", "legendFormat": "heap alloc (live)", "refId": "A" },
        { "expr": "go_memstats_heap_inuse_bytes", "legendFormat": "heap in-use", "refId": "B" },
        { "expr": "go_memstats_heap_sys_bytes", "legendFormat": "heap sys (from OS)", "refId": "C" },
        { "expr": "go_memstats_stack_inuse_bytes", "legendFormat": "stack in-use", "refId": "D" }
      ],
      "title": "Heap & Stack Memory", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 }, "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "goroutines", "refId": "A" },
        { "expr": "go_memstats_heap_objects", "legendFormat": "heap objects", "refId": "B" }
      ],
      "title": "Goroutines & Heap Objects", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 }, "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "go_gc_duration_seconds{quantile=\"0.5\"}", "legendFormat": "p50 GC pause", "refId": "A" },
        { "expr": "go_gc_duration_seconds{quantile=\"0.75\"}", "legendFormat": "p75 GC pause", "refId": "B" },
        { "expr": "go_gc_duration_seconds{quantile=\"1\"}", "legendFormat": "max GC pause", "refId": "C" },
        { "expr": "go_memstats_gc_cpu_fraction * 100", "legendFormat": "GC CPU %", "refId": "D" }
      ],
      "title": "GC Pause & CPU Fraction", "type": "timeseries" },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 201, "title": "Upload - Overview", "type": "row" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 }, "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(hades_upload_requests_total[5m])", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "title": "Upload RPS", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 }, "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(hades_upload_duration_ms_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(hades_upload_duration_ms_bucket[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(hades_upload_duration_ms_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Upload Latency - CPU proxy (ms)", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 }, "id": 12,
