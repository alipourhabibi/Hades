        { "expr": "histogram_quantile(0.50, rate(hades_upload_proto_bytes_bucket[5m]))", "legendFormat": "p50 proto bytes", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(hades_upload_proto_bytes_bucket[5m]))", "legendFormat": "p95 proto bytes", "refId": "B" },
        { "expr": "rate(hades_upload_proto_bytes_sum[5m]) / rate(hades_upload_proto_bytes_count[5m])", "legendFormat": "avg proto bytes", "refId": "C" }
      ],
      "title": "Upload Proto Bytes - Storage I/O (SSD write to Gitaly)", "type": "timeseries" },

    { "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 }, "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(hades_upload_file_count_bucket[5m]))", "legendFormat": "p50 files", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(hades_upload_file_count_bucket[5m]))", "legendFormat": "p95 files", "refId": "B" }
      ],
      "title": "Upload File Count per Request", "type": "timeseries" },

