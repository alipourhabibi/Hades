{$DOMAIN:example.com} {
    tls internal

    # RPC traffic (gRPC, Connect-RPC, JSON) → Hades backend (h2c)
    # Matches all service paths: /hades.api.* and /buf.registry.*
    @rpc path /hades.api.* /buf.registry.*
    reverse_proxy @rpc hades:50051 {
        transport http {
            versions h2c
        }
    }

    # Everything else → Next.js frontend
    reverse_proxy frontend:3000
}
