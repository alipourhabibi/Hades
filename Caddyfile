{$DOMAIN:example.com} {
    tls internal

    # RPC traffic (gRPC, Connect-RPC, JSON) + Go module proxy → Hades backend (h2c)
    # Matches: /hades.api.*, /buf.registry.*, /gen/go/* (go-import discovery), /go/* (GOPROXY)
    @rpc path /hades.api.* /buf.registry.* /gen/go/* /go/*
    reverse_proxy @rpc hades:50051 {
        transport http {
            versions h2c
        }
    }

    # Everything else → Next.js frontend
    reverse_proxy frontend:3000
}
